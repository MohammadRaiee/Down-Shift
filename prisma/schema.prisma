generator client {
  provider = "prisma-client-js"
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "./ERD.svg"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Seller {
  id              Int      @id @default(autoincrement())
  firstName       String
  lastName        String
  email           String   @unique
  password        String
  phone           String
  storeName       String
  businessType    String
  businessReg     String?
  storeLogo       String?
  GPSLocation     String?
  address         String
  city            String
  shippingOptions String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isActive        Boolean  @default(true)
  parts           Parts[]
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  firstName    String?
  lastName     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isVerified   Boolean  @default(false)
  image        String?
  carts        Cart[]
}

model CarBrand {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now())
  models    CarModel[]
}

model CarModel {
  id        Int       @id @default(autoincrement())
  brandId   Int
  name      String
  year      Int
  createdAt DateTime  @default(now())
  brand     CarBrand  @relation(fields: [brandId], references: [id])
  parts     PartCar[]
}

model Parts {


  id              Int       @id @default(autoincrement())
  name            String
  partNumber      String?   @unique
  price           Float
  description     String?
  publisherId     Int
  createdAt       DateTime  @default(now())
  image           String[]
  countryOfOrigin String
  quality         String    @default("Good")
  cars            PartCar[]
  publisher       Seller    @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  categoryId      Int?
  category        Category? @relation(fields: [categoryId], references: [id])
  cartItems       CartItem[]
}

model Category {
  id    Int     @id @default(autoincrement())
  name  String  @unique
  parts Parts[]
}

model PartCar {
  id         Int      @id @default(autoincrement())
  partId     Int
  carModelId Int
  carModel   CarModel @relation(fields: [carModelId], references: [id], onDelete: Cascade)
  part       Parts    @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@unique([partId, carModelId])
}


model Cart {
  id        Int        @id @default(autoincrement())
  user      User?      @relation(fields: [userId], references: [id])
  userId    Int?       @unique
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cart      Cart     @relation(fields: [cartId], references: [id])
  cartId    Int
  part      Parts    @relation(fields: [partId], references: [id])
  partId    Int
  quantity  Int
  priceAtAdd Float
  options   Json?
  key       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, key])
}
